
     git branch: 'main',url:'https://github.com/hongseunghyun123/cicd-test.git'
              }
            }
            stage('Git clone end') {
              steps {
                  sh 'touch cicd_test.txt'
                  sh 'echo "git clone end" > cicd_test.txt'
               }
        }
    }
}
